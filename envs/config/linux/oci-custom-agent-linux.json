{
  "agent": {
    "namespace": "custom_oracle_linux",
    "resource_group": "os"
  },
  "disk": {
    "exclude_fstypes": [
      "proc",
      "sysfs",
      "tmpfs",
      "devtmpfs",
      "efivarfs",
      "cgroup",
      "cgroup2",
      "overlay",
      "squashfs",
      "nsfs",
      "rpc_pipefs",
      "autofs"
    ]
  },
  "procstat": [
    {
      "name": "nginx",
      "pattern": "/usr/sbin/nginx"
    }
  ]
}
