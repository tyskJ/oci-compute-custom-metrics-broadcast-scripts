{
  "agent": {
    "namespace": "custom_windows_server",
    "resource_group": "os",
    "error_log_path": "C:\\ProgramData\\oci-custom-agent\\error.log",
    "error_log_backup_days": 7,
    "error_log_use_utc": false
  },
  "disk": {
    "drive_letters": ["c"]
  },
  "procstat": [
    {
      "name": "nginx",
      "pattern": "nginx.exe"
    }
  ]
}
